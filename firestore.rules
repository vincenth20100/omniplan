rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isGlobalAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // --- Functions for reading existing documents ---
    function isProjectMember(projectId) {
      return isSignedIn() && exists(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid));
    }
    
    function isProjectEditor(projectId) {
      let userRole = get(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid)).data.role;
      return isProjectMember(projectId) && userRole in ['owner', 'editor'];
    }

    function isProjectOwner(projectId) {
      let userRole = get(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid)).data.role;
      return isProjectMember(projectId) && userRole == 'owner';
    }

    // --- Functions for batched writes (creation) ---
    function isProjectEditorAfter(projectId) {
      // Use getAfter to read the state of a document after the write operation completes.
      return isSignedIn() && getAfter(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid)).data.role in ['owner', 'editor'];
    }

    // --- User Profile ---
    match /users/{userId} {
      allow read, create, update: if request.auth.uid == userId || isGlobalAdmin();
      allow delete: if false;
    }

    // --- Projects and Subcollections ---
    match /projects/{projectId} {
      // Project Document
      allow read: if isProjectMember(projectId) || isGlobalAdmin();
      allow list: if isGlobalAdmin();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isProjectEditor(projectId) || isGlobalAdmin();
      allow delete: if isProjectOwner(projectId) || isGlobalAdmin();

      // Project Members
      match /members/{userId} {
        allow read, list: if isProjectMember(projectId) || isGlobalAdmin();
        // Allow a user to create their own membership doc IF they are the project owner (checked via getAfter)
        // OR allow an existing owner/admin to add/edit members.
        allow create: if (getAfter(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid && request.auth.uid == userId) || isProjectOwner(projectId) || isGlobalAdmin();
        // An editor can change roles, but not to 'owner'. An owner can change anyone, but we restrict them from promoting others to 'owner' to prevent mistakes.
        allow update: if isProjectEditor(projectId) && request.resource.data.role != 'owner';
        allow delete: if (isProjectOwner(projectId) && request.auth.uid != userId) || isGlobalAdmin();
      }

      // Tasks
      match /tasks/{taskId} {
        allow read, list: if isProjectMember(projectId) || isGlobalAdmin();
        allow create: if isProjectEditorAfter(projectId) || isGlobalAdmin();
        allow update, delete: if isProjectEditor(projectId) || isGlobalAdmin();
      }

      // Links
      match /links/{linkId} {
        allow read, list: if isProjectMember(projectId) || isGlobalAdmin();
        allow create: if isProjectEditorAfter(projectId) || isGlobalAdmin();
        allow update, delete: if isProjectEditor(projectId) || isGlobalAdmin();
      }

      // Resources
      match /resources/{resourceId} {
        allow read, list: if isProjectMember(projectId) || isGlobalAdmin();
        allow create: if isProjectEditorAfter(projectId) || isGlobalAdmin();
        allow update, delete: if isProjectEditor(projectId) || isGlobalAdmin();
      }
      
      // Assignments
      match /assignments/{assignmentId} {
        allow read, list: if isProjectMember(projectId) || isGlobalAdmin();
        allow create: if isProjectEditorAfter(projectId) || isGlobalAdmin();
        allow update, delete: if isProjectEditor(projectId) || isGlobalAdmin();
      }
      
      // Calendars
      match /calendars/{calendarId} {
        allow read, list: if isProjectMember(projectId) || isGlobalAdmin();
        allow create: if isProjectEditorAfter(projectId) || isGlobalAdmin();
        allow update, delete: if isProjectEditor(projectId) || isGlobalAdmin();
      }
      
      // Views
      match /views/{viewId} {
        allow read, list: if isProjectMember(projectId) || isGlobalAdmin();
        allow create, update, delete: if isProjectEditor(projectId) || isGlobalAdmin();
      }

      // Settings
      match /settings/{settingId} {
        allow read, list: if isProjectMember(projectId) || isGlobalAdmin();
        allow create, update, delete: if isProjectEditor(projectId) || isGlobalAdmin();
      }

      // Other collections with same simple logic
      match /zones/{zoneId} {
        allow read, list: if isProjectMember(projectId) || isGlobalAdmin();
        allow create: if isProjectEditorAfter(projectId) || isGlobalAdmin();
        allow update, delete: if isProjectEditor(projectId) || isGlobalAdmin();
      }
      match /history_logs/{historyLogId} {
        allow read, list: if isProjectMember(projectId) || isGlobalAdmin();
        allow create: if isProjectEditorAfter(projectId) || isGlobalAdmin();
        allow update, delete: if isProjectEditor(projectId) || isGlobalAdmin();
      }
    }
     // --- Invitations ---
    match /invitations/{invitationId} {
      allow create: if isProjectEditor(request.resource.data.projectId) || isGlobalAdmin();
      allow list: if isSignedIn();
      allow delete: if isSignedIn();
      allow read: if false;
      allow update: if false;
    }
  }
}
