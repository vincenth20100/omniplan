rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isGlobalAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // --- Functions for reading existing documents ---
    function isProjectMember(projectId) {
      return isSignedIn() && exists(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid));
    }

    function isLegacyProjectMember(projectId) {
      // Fallback for projects that haven't been migrated to the `members` subcollection yet.
      // This costs an extra document read per access check.
      let projectDoc = get(/databases/$(database)/documents/projects/$(projectId));
      // Use hasAny for list membership check.
      return 'memberIds' in projectDoc.data && projectDoc.data.memberIds.hasAny([request.auth.uid]);
    }

    function isProjectViewer(projectId) {
      return isProjectMember(projectId) || isLegacyProjectMember(projectId);
    }
    
    function isProjectEditor(projectId) {
      let userRole = get(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid)).data.role;
      return isProjectMember(projectId) && userRole in ['owner', 'editor'];
    }

    function isProjectOwner(projectId) {
      let userRole = get(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid)).data.role;
      return isProjectMember(projectId) && userRole == 'owner';
    }

    // --- Functions for batched writes (creation) ---
    function isProjectEditorAfter(projectId) {
      // Use getAfter to read the state of a document after the write operation completes.
      return isSignedIn() && getAfter(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid)).data.role in ['owner', 'editor'];
    }

    // --- User Profile ---
    match /users/{userId} {
      allow read, create, update: if request.auth.uid == userId || isGlobalAdmin();
      allow delete: if false;
    }
    
    // --- User Preferences ---
    match /user_preferences/{prefId} {
      // Allow user to read/write their own preferences. prefId is formatted as {userId}_{projectId}
      allow read, create, update, delete: if isSignedIn() && request.auth.uid == prefId.split('_')[0];
    }


    // --- Global Links (for Collection Group Queries) ---
    match /{document=**}/links/{linkId} {
      allow read: if isSignedIn() && (
        (resource.data.sourceProjectId != null && isProjectViewer(resource.data.sourceProjectId)) ||
        (resource.data.targetProjectId != null && isProjectViewer(resource.data.targetProjectId))
      );
    }

    // --- Projects and Subcollections ---
    match /projects/{projectId} {
      // Project Document
      // FIX: Removed recursive call to isProjectViewer to break circular dependency.
      // This allows get() calls from other rules (for legacy checks) to succeed.
      // The direct check on `resource.data.memberIds` handles direct reads of the project doc for legacy members.
      allow read: if isProjectMember(projectId) || isGlobalAdmin() || (resource.data.memberIds.hasAny([request.auth.uid]));
      allow list: if isGlobalAdmin();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isProjectEditor(projectId) || isGlobalAdmin();
      allow delete: if isProjectOwner(projectId) || isGlobalAdmin();

      // Project Members
      match /members/{userId} {
        allow read, list: if isProjectViewer(projectId) || isGlobalAdmin();
        // Allow a user to create their own membership doc IF they are the project owner (checked via getAfter)
        // OR allow an existing owner/admin to add/edit members.
        allow create: if (getAfter(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid && request.auth.uid == userId) || isProjectOwner(projectId) || isGlobalAdmin();
        // An editor can change roles, but not to 'owner'. An owner can change anyone, but we restrict them from promoting others to 'owner' to prevent mistakes.
        allow update: if isProjectEditor(projectId) && request.resource.data.role != 'owner';
        allow delete: if isProjectOwner(projectId) || isGlobalAdmin();
      }

      // Tasks
      match /tasks/{taskId} {
        allow read, list: if isProjectViewer(projectId) || isGlobalAdmin();
        allow create: if isProjectEditorAfter(projectId) || isGlobalAdmin();
        allow update, delete: if isProjectEditor(projectId) || isGlobalAdmin();
      }

      // Links
      match /links/{linkId} {
        allow read, list: if isProjectViewer(projectId) || isGlobalAdmin();
        allow create: if isProjectEditorAfter(projectId) || isGlobalAdmin();
        allow update, delete: if isProjectEditor(projectId) || isGlobalAdmin();
      }

      // Baselines
      match /baselines/{baselineId} {
        allow read, list: if isProjectViewer(projectId) || isGlobalAdmin();
        allow create: if isProjectEditorAfter(projectId) || isGlobalAdmin();
        allow update, delete: if isProjectEditor(projectId) || isGlobalAdmin();
      }

      // Resources
      match /resources/{resourceId} {
        allow read, list: if isProjectViewer(projectId) || isGlobalAdmin();
        allow create: if isProjectEditorAfter(projectId) || isGlobalAdmin();
        allow update, delete: if isProjectEditor(projectId) || isGlobalAdmin();
      }
      
      // Assignments
      match /assignments/{assignmentId} {
        allow read, list: if isProjectViewer(projectId) || isGlobalAdmin();
        allow create: if isProjectEditorAfter(projectId) || isGlobalAdmin();
        allow update, delete: if isProjectEditor(projectId) || isGlobalAdmin();
      }
      
      // Calendars
      match /calendars/{calendarId} {
        allow read, list: if isProjectViewer(projectId) || isGlobalAdmin();
        allow create: if isProjectEditorAfter(projectId) || isGlobalAdmin();
        allow update, delete: if isProjectEditor(projectId) || isGlobalAdmin();
      }
      
      // Views
      match /views/{viewId} {
        allow read, list: if isProjectViewer(projectId) || isGlobalAdmin();
        allow create, update, delete: if isProjectEditor(projectId) || isGlobalAdmin();
      }

      // Settings
      match /settings/{settingId} {
        allow read, list: if isProjectViewer(projectId) || isGlobalAdmin();
        allow create, update, delete: if isProjectEditor(projectId) || isGlobalAdmin();
      }

      // Other collections with same simple logic
      match /zones/{zoneId} {
        allow read, list: if isProjectViewer(projectId) || isGlobalAdmin();
        allow create: if isProjectEditorAfter(projectId) || isGlobalAdmin();
        allow update, delete: if isProjectEditor(projectId) || isGlobalAdmin();
      }
      match /history/{historyId} {
        allow read, list: if isProjectViewer(projectId) || isGlobalAdmin();
        allow create: if isProjectEditorAfter(projectId) || isGlobalAdmin();
        allow update, delete: if isProjectEditor(projectId) || isGlobalAdmin();
      }

      // Snapshots
      match /snapshots/{snapshotId} {
        allow read, list: if isProjectViewer(projectId) || isGlobalAdmin();
        allow create: if isProjectEditor(projectId) || isGlobalAdmin();
        allow delete: if isProjectEditor(projectId) || isGlobalAdmin();
      }
    }
     // --- Invitations ---
    match /invitations/{invitationId} {
      allow create: if isProjectEditor(request.resource.data.projectId) || isGlobalAdmin();
      allow list: if isSignedIn();
      allow delete: if isSignedIn();
      allow read: if false;
      allow update: if false;
    }
  }
}
