rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // --- Functions for reading existing documents ---
    function isProjectMember(projectId) {
      return isSignedIn() && exists(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid));
    }
    
    function isProjectEditor(projectId) {
      let userRole = get(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid)).data.role;
      return isProjectMember(projectId) && userRole in ['owner', 'editor'];
    }

    function isProjectOwner(projectId) {
      let userRole = get(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid)).data.role;
      return isProjectMember(projectId) && userRole == 'owner';
    }

    // --- Functions for batched writes (creation) ---
    function isProjectEditorAfter(projectId) {
      // Use getAfter to read the state of a document after the write operation completes.
      return isSignedIn() && getAfter(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid)).data.role in ['owner', 'editor'];
    }

    // --- User Profile ---
    match /users/{userId} {
      allow read, create, update: if request.auth.uid == userId;
      allow delete: if false;
    }

    // --- Projects and Subcollections ---
    match /projects/{projectId} {
      // Project Document
      allow read: if isProjectMember(projectId);
      allow list: if false; // Users should query based on their own user doc
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isProjectEditor(projectId); // e.g., renaming the project
      allow delete: if isProjectOwner(projectId);

      // Project Members
      match /members/{userId} {
        allow read, list: if isProjectMember(projectId);
        // Allow a user to create their own membership doc IF they are the project owner (checked via getAfter)
        // OR allow an existing owner to add/edit members.
        allow create: if (getAfter(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid && request.auth.uid == userId) || isProjectOwner(projectId);
        allow update, delete: if isProjectOwner(projectId);
      }

      // Tasks
      match /tasks/{taskId} {
        allow read, list: if isProjectMember(projectId);
        allow create: if isProjectEditorAfter(projectId);
        allow update, delete: if isProjectEditor(projectId);
      }

      // Links
      match /links/{linkId} {
        allow read, list: if isProjectMember(projectId);
        allow create: if isProjectEditorAfter(projectId);
        allow update, delete: if isProjectEditor(projectId);
      }

      // Resources
      match /resources/{resourceId} {
        allow read, list: if isProjectMember(projectId);
        allow create: if isProjectEditorAfter(projectId);
        allow update, delete: if isProjectEditor(projectId);
      }
      
      // Assignments
      match /assignments/{assignmentId} {
        allow read, list: if isProjectMember(projectId);
        allow create: if isProjectEditorAfter(projectId);
        allow update, delete: if isProjectEditor(projectId);
      }
      
      // Calendars
      match /calendars/{calendarId} {
        allow read, list: if isProjectMember(projectId);
        allow create: if isProjectEditorAfter(projectId);
        allow update, delete: if isProjectEditor(projectId);
      }
      
      // Views
      match /views/{viewId} {
        allow read, list: if isProjectMember(projectId);
        allow create, update, delete: if isProjectEditor(projectId);
      }

      // Settings
      match /settings/{settingId} {
        allow read, list: if isProjectMember(projectId);
        allow create, update, delete: if isProjectEditor(projectId);
      }

      // Other collections with same simple logic
      match /zones/{zoneId} {
        allow read, list: if isProjectMember(projectId);
        allow create: if isProjectEditorAfter(projectId);
        allow update, delete: if isProjectEditor(projectId);
      }
      match /history_logs/{historyLogId} {
        allow read, list: if isProjectMember(projectId);
        allow create: if isProjectEditorAfter(projectId);
        allow update, delete: if isProjectEditor(projectId);
      }
    }
  }
}
