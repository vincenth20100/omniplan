{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "Represents a single project, containing tasks, links, etc.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the project."
        },
        "name": {
          "type": "string",
          "description": "Name of the project."
        },
        "description": {
          "type": "string",
          "description": "A brief description of the project."
        },
        "ownerId": {
          "type": "string",
          "description": "The UID of the user who owns the project."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when the project was created."
        },
        "memberIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "A list of user UIDs who are members of this project."
        }
      },
      "required": ["id", "name", "ownerId", "createdAt"]
    },
    "ProjectMember": {
      "title": "Project Member",
      "description": "Represents a user's membership and role within a project.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user."
        },
        "role": {
          "type": "string",
          "enum": ["owner", "editor", "viewer"],
          "description": "The user's role in the project."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "description": "The user's photo URL."
        },
        "permissions": {
          "type": "object",
          "description": "Defines user-specific permissions for the project.",
          "properties": {
            "hiddenColumns": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "An array of column IDs that should be hidden for this user."
            }
          }
        }
      },
      "required": ["userId", "role"]
    },
    "User": {
      "title": "User",
      "description": "Represents a user's app-specific data, like their list of projects.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "projectIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "Invitation": {
      "title": "Invitation",
      "description": "An invitation for a user to join a project.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email of the user being invited."
        },
        "projectId": {
          "type": "string",
          "description": "ID of the project they are invited to."
        },
        "role": {
          "type": "string",
          "enum": [
            "editor",
            "viewer"
          ],
          "description": "Role assigned to the user."
        },
        "invitedBy": {
          "type": "string",
          "description": "UID of the user who sent the invitation."
        }
      },
      "required": [
        "email",
        "projectId",
        "role",
        "invitedBy"
      ]
    },
    "Task": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Task",
      "type": "object",
      "description": "Represents a task within the OmniPlan AI project management application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the task."
        },
        "name": {
          "type": "string",
          "description": "Name of the task."
        },
        "duration": {
          "type": "number",
          "description": "Duration of the task in working days."
        },
        "durationUnit": {
          "type": "string",
          "enum": [
            "d",
            "m",
            "ed",
            "em"
          ],
          "description": "The unit for the task's duration."
        },
        "start": {
          "type": "string",
          "description": "Start date and time of the task.",
          "format": "date-time"
        },
        "finish": {
          "type": "string",
          "description": "Finish date and time of the task.",
          "format": "date-time"
        },
        "percentComplete": {
          "type": "number",
          "description": "Percentage of the task that is complete (0-100)."
        },
        "status": {
          "type": "string",
          "enum": [
            "To Do",
            "In Progress",
            "Done"
          ],
          "description": "The current status of the task, used for Kanban view."
        },
        "constraintType": {
          "type": [
            "string",
            "null"
          ],
          "description": "Type of constraint applied to the task (e.g., 'Start No Earlier Than', 'Must Start On'). Nullable."
        },
        "constraintDate": {
          "type": [
            "string",
            "null"
          ],
          "description": "Date associated with the constraint. Nullable.",
          "format": "date-time"
        },
        "zoneId": {
          "type": [
            "string",
            "null"
          ],
          "description": "Reference to the Zone entity where the task is spatially located. Nullable. (Relationship: Zone 1:N Task)"
        },
        "customAttributes": {
          "type": [
            "string",
            "null"
          ],
          "description": "JSON string containing custom attributes for the task. Nullable."
        },
        "schedulingConflict": {
          "type": "boolean",
          "description": "Indicates if there is a scheduling conflict for the task."
        },
        "order": {
          "type": "number",
          "description": "Sort order of the task."
        },
        "parentId": {
          "type": [
            "string",
            "null"
          ],
          "description": "Reference to the parent task for hierarchical structure."
        },
        "isCollapsed": {
          "type": "boolean",
          "description": "Whether the summary task is collapsed in the UI."
        },
        "cost": {
          "type": "number",
          "description": "The cost of the task."
        },
        "deadline": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time",
          "description": "An optional deadline for the task."
        },
        "notes": {
          "type": "array",
          "items": {
            "$ref": "#/entities/Note"
          },
          "description": "A list of notes or activity logs for the task."
        },
        "additionalNotes": {
          "type": [
            "string",
            "null"
          ],
          "description": "Persistent, high-level notes about the task."
        }
      },
      "required": [
        "id",
        "name",
        "duration",
        "start",
        "finish",
        "percentComplete"
      ]
    },
    "Note": {
      "title": "Note",
      "description": "Represents a note or log entry on a task.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "author": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "author",
        "content",
        "timestamp"
      ]
    },
    "Link": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Link",
      "type": "object",
      "description": "Represents a dependency link between two tasks.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the link."
        },
        "source": {
          "type": "string",
          "description": "Reference to the source (predecessor) task."
        },
        "target": {
          "type": "string",
          "description": "Reference to the target (successor) task."
        },
        "type": {
          "type": "string",
          "description": "Type of link (FS, SS, FF, SF)."
        },
        "lag": {
          "type": "number",
          "description": "Lag time (buffer) in working days."
        }
      },
      "required": [
        "id",
        "source",
        "target",
        "type",
        "lag"
      ]
    },
    "Zone": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Zone",
      "type": "object",
      "description": "Represents a spatial zone defined on the 4D map.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the zone."
        },
        "name": {
          "type": "string",
          "description": "Name of the zone."
        },
        "coordinates": {
          "type": "string",
          "description": "JSON string containing the coordinates of the polygon defining the zone."
        }
      },
      "required": [
        "id",
        "name",
        "coordinates"
      ]
    },
    "HistoryLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "HistoryLog",
      "type": "object",
      "description": "Represents a log entry for changes made to the application state.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the history log entry."
        },
        "timestamp": {
          "type": "string",
          "description": "Timestamp of when the change occurred.",
          "format": "date-time"
        },
        "actionType": {
          "type": "string",
          "description": "Type of action that triggered the change (e.g., 'CREATE_TASK', 'UPDATE_TASK')."
        },
        "entityType": {
          "type": "string",
          "description": "The entity type that was modified (e.g., 'Task', 'Link')."
        },
        "entityId": {
          "type": "string",
          "description": "ID of the specific entity that was modified."
        },
        "previousState": {
          "type": "string",
          "description": "JSON string representing the state of the entity before the change."
        },
        "newState": {
          "type": "string",
          "description": "JSON string representing the state of the entity after the change."
        }
      },
      "required": [
        "id",
        "timestamp",
        "actionType",
        "entityType",
        "entityId",
        "previousState",
        "newState"
      ]
    },
    "Resource": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Resource",
      "type": "object",
      "description": "Represents a resource that can be assigned to tasks.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the resource."
        },
        "name": {
          "type": "string",
          "description": "Name of the resource."
        },
        "category": {
          "type": "string",
          "description": "Category of the resource."
        },
        "type": {
          "type": "string",
          "enum": [
            "Work",
            "Material",
            "Cost"
          ],
          "description": "Type of the resource."
        },
        "costPerHour": {
          "type": "number",
          "description": "Cost per hour for work resources."
        },
        "availability": {
          "type": "number",
          "description": "Availability of the resource (e.g., 1 for 100%)."
        },
        "calendarId": {
          "type": "string",
          "description": "Reference to the calendar for this resource."
        }
      },
      "required": [
        "id",
        "name",
        "type"
      ]
    },
    "Assignment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Assignment",
      "type": "object",
      "description": "Links a task to a resource.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the assignment."
        },
        "taskId": {
          "type": "string",
          "description": "ID of the assigned task."
        },
        "resourceId": {
          "type": "string",
          "description": "ID of the assigned resource."
        }
      },
      "required": [
        "id",
        "taskId",
        "resourceId"
      ]
    },
    "Exception": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Exception",
      "type": "object",
      "description": "Represents a non-working period in a calendar.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "start": {
          "type": "string",
          "format": "date-time"
        },
        "finish": {
          "type": "string",
          "format": "date-time"
        },
        "isActive": {
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "name",
        "start",
        "finish"
      ]
    },
    "Calendar": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Calendar",
      "type": "object",
      "description": "Defines working and non-working time for scheduling.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "workingDays": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "exceptions": {
          "type": "array",
          "items": {
            "$ref": "#/entities/Exception"
          }
        },
        "nonWorkingDayOverrides": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "workingDayOverrides": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "id",
        "name",
        "workingDays"
      ]
    },
    "View": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "View",
      "description": "Represents a saved view configuration including columns, grouping, and filters.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "grouping": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "visibleColumns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "filters": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "columnId": {
                "type": "string"
              },
              "operator": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "columnId",
              "operator"
            ]
          }
        }
      },
      "required": [
        "id",
        "name"
      ]
    },
    "UserSettings": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User Settings",
      "description": "Stores user-specific application settings.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "currentViewId": {
          "type": "string"
        },
        "uiDensity": {
          "type": "string",
          "enum": [
            "compact",
            "medium",
            "large"
          ]
        },
        "columns": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "width": {
                "type": "number"
              },
              "type": {
                "type": "string"
              },
              "options": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "id",
              "name",
              "width"
            ]
          }
        },
        "ganttSettings": {
          "type": "object",
          "properties": {
            "viewMode": {
              "type": "string"
            },
            "showDependencies": {
              "type": "boolean"
            },
            "showProgress": {
              "type": "boolean"
            },
            "highlightNonWorkingTime": {
              "type": "boolean"
            },
            "showTodayLine": {
              "type": "boolean"
            },
            "showTaskLabels": {
              "type": "boolean"
            },
            "highlightCriticalPath": {
              "type": "boolean"
            }
          }
        }
      },
      "required": [
        "id"
      ]
    }
  },
  "auth": {
    "providers": [
      "google.com",
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/entities/User"
          },
          "description": "Stores user-specific data, primarily their project memberships."
        }
      },
      {
        "path": "/projects/{projectId}",
        "definition": {
          "entityName": "Project",
          "schema": {
            "$ref": "#/entities/Project"
          },
          "description": "Root collection for all projects."
        }
      },
      {
        "path": "/projects/{projectId}/members/{userId}",
        "definition": {
          "entityName": "ProjectMember",
          "schema": {
            "$ref": "#/entities/ProjectMember"
          },
          "description": "Stores members and their roles for a specific project."
        }
      },
      {
        "path": "/invitations/{invitationId}",
        "definition": {
          "entityName": "Invitation",
          "schema": {
            "$ref": "#/entities/Invitation"
          },
          "description": "Stores pending invitations for users to join projects."
        }
      },
      {
        "path": "/projects/{projectId}/tasks/{taskId}",
        "definition": {
          "entityName": "Task",
          "schema": {
            "$ref": "#/entities/Task"
          }
        }
      },
      {
        "path": "/projects/{projectId}/links/{linkId}",
        "definition": {
          "entityName": "Link",
          "schema": {
            "$ref": "#/entities/Link"
          }
        }
      },
      {
        "path": "/projects/{projectId}/zones/{zoneId}",
        "definition": {
          "entityName": "Zone",
          "schema": {
            "$ref": "#/entities/Zone"
          }
        }
      },
      {
        "path": "/projects/{projectId}/history_logs/{historyLogId}",
        "definition": {
          "entityName": "HistoryLog",
          "schema": {
            "$ref": "#/entities/HistoryLog"
          }
        }
      },
      {
        "path": "/projects/{projectId}/resources/{resourceId}",
        "definition": {
          "entityName": "Resource",
          "schema": {
            "$ref": "#/entities/Resource"
          }
        }
      },
      {
        "path": "/projects/{projectId}/assignments/{assignmentId}",
        "definition": {
          "entityName": "Assignment",
          "schema": {
            "$ref": "#/entities/Assignment"
          }
        }
      },
      {
        "path": "/projects/{projectId}/calendars/{calendarId}",
        "definition": {
          "entityName": "Calendar",
          "schema": {
            "$ref": "#/entities/Calendar"
          }
        }
      },
      {
        "path": "/projects/{projectId}/views/{viewId}",
        "definition": {
          "entityName": "View",
          "schema": {
            "$ref": "#/entities/View"
          }
        }
      },
      {
        "path": "/projects/{projectId}/settings/{settingId}",
        "definition": {
          "entityName": "UserSettings",
          "schema": {
            "$ref": "#/entities/UserSettings"
          },
          "description": "This now stores project-specific settings, but shared among users of the project. A single doc 'app_settings' is used."
        }
      }
    ]
  }
}
